# ── Firebase (authentication) ────────────────────────────────────────────
# From Firebase console → Project settings → Your apps → Web app config.
# Until these are set the app runs in demo mode (auth simulated, sample data).
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (server-only — NEVER prefix with NEXT_PUBLIC_) ─────────
# From Firebase console → Project settings → Service accounts → Generate key.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ── Contextual Intelligence Business Dashboard API ────────────────────────
# Base URL + service token from the API handout. Server-side only — the
# dashboard proxies all calls so the token never reaches the browser.
CI_API_BASE_URL=
CI_API_TOKEN=

# ── Stripe (billing) ──────────────────────────────────────────────────────
# Dashboard → Developers → API keys. Until set, billing buttons show a
# friendly "add your keys" notice instead of redirecting to Stripe.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Price IDs for each plan (Dashboard → Products).
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_ENTERPRISE=

# Optional: a customer id so "Manage in Stripe" works before real customers exist.
STRIPE_DEMO_CUSTOMER_ID=
